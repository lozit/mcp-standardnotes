# Standard Notes server endpoint
SN_SERVER_URL=https://api.standardnotes.com

# Account email (password is NEVER set here — run `npm run login` once)
SN_EMAIL=you@example.com

# Optional: pin TLS cert SHA-256 fingerprint for self-hosted servers
# SN_CERT_FINGERPRINT=

# Optional: override keychain service name
# KEYCHAIN_SERVICE=mcp-standardnotes
